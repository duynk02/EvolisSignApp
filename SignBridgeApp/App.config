<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <!-- Cổng HTTP mà Bridge app lắng nghe. HIS sẽ gọi http://localhost:<port>/api/sign -->
    <add key="ListenPort" value="4033" />

    <!-- "localhost" = CHỈ app trên CHÍNH máy này gọi được (mặc định, an toàn
         nhất, đúng với mô hình HIS + Bridge app cùng 1 máy).
         "+" = lắng nghe trên mọi địa chỉ mạng (LAN) - cần chạy app với quyền
         Admin, hoặc đã chạy lệnh netsh (xem README) trước khi dùng. -->
    <add key="BindAddress" value="localhost" />

    <!-- Thư mục lưu ảnh chữ ký đã ký -->
    <add key="OutputFolder" value="D:\SignBridge\SignedImages" />

    <!-- Index thiết bị signotec (0 = thiết bị đầu tiên/duy nhất cắm vào máy) -->
    <add key="DeviceIndex" value="0" />

    <!-- Để trống = không yêu cầu xác thực (phù hợp khi chỉ bind localhost).
         Nếu đặt giá trị, mọi request gọi tới phải có header:
         X-Api-Key: <giá trị này> -->
    <add key="ApiKey" value="" />
  </appSettings>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.6.2" />
  </startup>
</configuration>
